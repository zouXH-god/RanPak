{
  "name": "ran-pak-app",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "dist:win": "electron-builder --win nsis --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@alicloud/alidns20150109": "^4.4.1",
    "cloudflare": "^6.2.0",
    "docx": "^9.7.1",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "tencentcloud-sdk-nodejs": "^4.1.232",
    "yaml": "^2.9.0"
  },
  "build": {
    "appId": "com.ranpak.app",
    "productName": "RanPak",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "services/**/*",
      "assets/**/*",
      "config/**/*",
      "web-dist/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "win": {
      "icon": "assets/icons/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
